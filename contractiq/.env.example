# =============================================================================
# ContractIQ — Environment Variables
# Copy this file to .env.local and fill in real values before running the app.
# Never commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get all three values from: Supabase Dashboard > Settings > API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=           # e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # "anon / public" key — safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY — never expose to browser or client code

# -----------------------------------------------------------------------------
# OpenAI
# Get from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=                     # SERVER ONLY — sk-... key used for GPT-4o extraction and chat

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Full URL of the app — used in auth email redirects

# -----------------------------------------------------------------------------
# Rate limiting & token limits
# -----------------------------------------------------------------------------
MAX_CHAT_HISTORY=100                        # Max messages sent to the model per chat request
